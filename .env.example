# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 開発用: TweaksPanel (テーマ・密度切替) を有効化
# NEXT_PUBLIC_ENABLE_TWEAKS=1

# ─── Supabase ───
# 未設定時は in-memory モードで起動 (ローカル開発で env なしでもUI動作確認可)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Keepa ───
# 未設定時はモック時系列＋プレースホルダー画像を表示。
# 設定すると価格/BSR 履歴に加えて imagesCSV から商品画像 URL を取得し、
# 一覧・詳細画面で実際の Amazon 画像が表示される。
# 取得方法: https://keepa.com/#!api （Plan 50: ¥1,800/月程度〜、初月 1,200 token 付与）
KEEPA_API_KEY=
KEEPA_DOMAIN=5  # 5 = Amazon.co.jp / 1 = .com / 8 = .uk

# ─── LLM Provider ───
# gemini | openai | anthropic | mock
LLM_PROVIDER=gemini
GEMINI_API_KEY=
# 既定: gemini-1.5-flash (@google/generative-ai 0.24 + AI Studio 標準キーで最も安定)。
# 利用可能候補:
#   gemini-1.5-flash      … 推奨 (無料枠 / 高速)
#   gemini-1.5-flash-002  … 1.5-flash の固定版
#   gemini-1.5-pro        … 高品質だがレート制限厳しめ
#   gemini-2.0-flash-exp  … experimental (一部キーで 404)
#   gemini-2.5-pro        … Vertex / 有料向け
# GEMINI_MODEL=gemini-1.5-flash
# (オプション) provider 切替用
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Cron ───
# `Authorization: Bearer ${CRON_SECRET}` で /api/refresh 保護
CRON_SECRET=

# ─── Notifications (オプション) ───
# Slack/Discord/Webhook URL — 監視リスト再評価で重大変化を通知
NOTIFY_WEBHOOK_URL=

# ─── Cost ───
# 月予算 (¥) — 80% 超過で cache_only_mode を有効化
COST_BUDGET_JPY=10000
